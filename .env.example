# =============================================================================
# KARTO — переменные окружения (production / staging)
# Скопируйте в .env.local для разработки или задайте на сервере (Timeweb/Vercel).
# Секреты НЕ коммитьте в git.
# =============================================================================

# --- Обязательные (сайт не работает без них) ---

NEXT_PUBLIC_APP_URL=https://karto.pro

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

OPENROUTER_API_KEY=
# Прокси только для OpenRouter (опционально; не используйте TELEGRAM_PROXY):
# OPENROUTER_PROXY=
# OPENROUTER_PROXY_USER=
# OPENROUTER_PROXY_PASSWORD=
# Или стандартные HTTPS_PROXY / HTTP_PROXY.

# Модели OpenRouter (опционально; defaults сохраняют качество как на Replicate/Qwen)
# OPENROUTER_VISION_PRIMARY_MODEL=openai/gpt-4o-mini
# OPENROUTER_VISION_FALLBACK_MODEL=anthropic/claude-sonnet-4
# OPENROUTER_SUGGEST_NAMES_MODEL=openai/gpt-4o-mini
# OPENROUTER_DESCRIPTION_MODEL=openai/gpt-4o-mini
# OPENROUTER_DESCRIPTION_FALLBACK_MODEL=anthropic/claude-sonnet-4
# OPENROUTER_CONCEPT_MODEL=openai/gpt-4o-mini

# Платежи ЮKassa — боевой магазин (ключ live_..., Shop ID в кабинете, напр. 1279533)
# На Timeweb те же переменные в настройках приложения. Тест локально: YOOKASSA_TEST_LOCAL.md
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Регистрация / коды подтверждения
SIGNUP_CODE_SECRET=

# --- Генерация изображений и видео (студия) ---

# KIE — видео, логотип бренда; free-gen при FREE_GEN_IMAGE_PROVIDER=kie
KIE_AI_API_KEY=

# WaveSpeed — Поток (визуал карточек) и свободное творчество (по умолчанию, если ключ задан)
WAVESPEED_API_KEY=
# Поток: kie | wavespeed | evolink | auto (auto = WaveSpeed, если ключ есть)
# FLOW_IMAGE_PROVIDER=auto
# Поток через KIE (стабильнее edit при тех же промптах): FLOW_IMAGE_PREFER_KIE=1
# FLOW_IMAGE_PREFER_KIE=1
# Пауза между стартом 4 карточек на WaveSpeed (мс), по умолчанию 2500
# WAVESPEED_BATCH_STAGGER_MS=2500
# FREE_GEN_IMAGE_PROVIDER=wavespeed
# EVOLINK_API_KEY=

# Replicate — только legacy image API (segment/enhance/background); студия vision/text → OpenRouter
# REPLICATE_API_TOKEN=

# --- Автоответы (модуль «Отзывы») ---

# Шифрование API-ключей маркетплейсов в БД (32+ символа, случайная строка)
# AUTO_REPLY_SECRETS_KEY=

# Cron: продление пакетов и синхронизация inbox (обязательно на production)
CRON_SECRET=

# В production фоновый cron (inbox + автоответы) стартует при SUPABASE_SERVICE_ROLE_KEY
# (см. instrumentation.ts, интервал 2 мин). Резерв: self-ping в start.js при CRON_SECRET.
# Дополнительно: внешний ping /api/cron/auto-reply-inbox-sync
# AUTO_REPLY_CRON=0  — отключить встроенный планировщик
# AUTO_REPLY_CRON=1  — включить в dev

# Модели OpenRouter для автоответов (опционально, есть defaults)
# OPENROUTER_AUTO_REPLY_MODEL=
# OPENROUTER_AUTO_REPLY_REVIEW_MODEL=

# Локальная разработка без реальных API маркетплейсов
# OZON_MOCK_INBOX=1
# Локальная разработка Потока без списания тарифа (только dev)
# FLOW_DEV_BYPASS=1

# --- Почта (регистрация, приветствие) ---

SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- OAuth Яндекс (вход через Яндекс ID) ---

# YANDEX_CLIENT_ID=
# YANDEX_CLIENT_SECRET=
# YANDEX_REDIRECT_URI=https://karto.pro/api/auth/yandex/callback

# --- Админка ---

ADMIN_STATS_EMAIL=
ADMIN_STATS_SECRET=
# COMMUNITY_SURVEY_ADMIN_SECRET=

# --- Аналитика и UI ---

NEXT_PUBLIC_YANDEX_METRIKA_ID=
# NEXT_PUBLIC_CONTACT_EMAIL=aiora.help@mail.ru

# --- Голосовой ввод (Salute Speech, опционально) ---

# SALUTE_SPEECH_AUTHORIZATION_KEY=
# TRANSCRIBE_LEGACY_AFTER_SALUTE=

# --- Прочее (обычно не требуется менять) ---

# NODE_ENV=production
# NEXT_PUBLIC_DEFAULT_VOICE_BROWSER=0
