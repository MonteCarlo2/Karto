# =============================================================================
# KARTO — переменные окружения (production / staging)
# Скопируйте в .env.local для разработки или задайте на сервере (Timeweb/Vercel).
# Секреты НЕ коммитьте в git.
# =============================================================================

# --- Обязательные (сайт не работает без них) ---

NEXT_PUBLIC_APP_URL=https://karto.pro

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

OPENROUTER_API_KEY=

# Платежи ЮKassa (обязательно для оплаты тарифов)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Регистрация / коды подтверждения
SIGNUP_CODE_SECRET=

# --- Генерация изображений и видео (студия) ---

# KIE — основной провайдер карточек, видео, слайдов
KIE_AI_API_KEY=

# WaveSpeed — free-gen и fallback (если FREE_GEN_IMAGE_PROVIDER=wavespeed)
WAVESPEED_API_KEY=
# FREE_GEN_IMAGE_PROVIDER=wavespeed
# EVOLINK_API_KEY=

# Replicate — upscale, whisper, batch (опционально)
# REPLICATE_API_TOKEN=

# --- Автоответы (модуль «Отзывы») ---

# Шифрование API-ключей маркетплейсов в БД (32+ символа, случайная строка)
# AUTO_REPLY_SECRETS_KEY=

# Cron: продление пакетов и синхронизация inbox (обязательно на production)
CRON_SECRET=

# В production cron включается автоматически при наличии CRON_SECRET + SUPABASE_SERVICE_ROLE_KEY
# AUTO_REPLY_CRON=1

# Модели OpenRouter для автоответов (опционально, есть defaults)
# OPENROUTER_AUTO_REPLY_MODEL=
# OPENROUTER_AUTO_REPLY_REVIEW_MODEL=

# Локальная разработка без реальных API маркетплейсов
# OZON_MOCK_INBOX=1

# --- Почта (регистрация, приветствие) ---

SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- OAuth Яндекс (вход через Яндекс ID) ---

# YANDEX_CLIENT_ID=
# YANDEX_CLIENT_SECRET=
# YANDEX_REDIRECT_URI=https://karto.pro/api/auth/yandex/callback

# --- Админка ---

ADMIN_STATS_EMAIL=
ADMIN_STATS_SECRET=
# COMMUNITY_SURVEY_ADMIN_SECRET=

# --- Аналитика и UI ---

NEXT_PUBLIC_YANDEX_METRIKA_ID=
# NEXT_PUBLIC_CONTACT_EMAIL=aiora.help@mail.ru

# --- Голосовой ввод (Salute Speech, опционально) ---

# SALUTE_SPEECH_AUTHORIZATION_KEY=
# TRANSCRIBE_LEGACY_AFTER_SALUTE=

# --- Прочее (обычно не требуется менять) ---

# NODE_ENV=production
# NEXT_PUBLIC_DEFAULT_VOICE_BROWSER=0
