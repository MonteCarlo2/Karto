# Скопируйте в infra/openseo/.env и подставьте ключи.
# DataForSEO: https://app.dataforseo.com/api-access (Base64 credentials)

DATAFORSEO_API_KEY=

# Опционально: Google Search Console OAuth (см. open-seo docs)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# BETTER_AUTH_SECRET=replace-with-32plus-random-chars

# Опционально: AI-агент SAM внутри OpenSEO (тот же OpenRouter, что у KARTO)
# OPENROUTER_API_KEY=

PORT=3001
